#!/usr/bin/make -f

export DH_VERBOSE=1

# Append build date to the binary package Version (without modifying debian/changelog).
#
# Defaults:
#   - AISH_DEB_APPEND_DATE=1  -> append +YYYYMMDD
#   - AISH_DEB_APPEND_DATE=0  -> keep original changelog version
#   - AISH_DEB_BUILD_DATE=... -> override date string
AISH_DEB_APPEND_DATE ?= 1
AISH_DEB_BUILD_DATE ?= $(shell date +%Y%m%d)

BASE_DEB_VERSION := $(shell dpkg-parsechangelog -SVersion)
ifeq ($(AISH_DEB_APPEND_DATE),0)
GENCONTROL_DEB_VERSION := $(BASE_DEB_VERSION)
else
GENCONTROL_DEB_VERSION := $(BASE_DEB_VERSION)+$(AISH_DEB_BUILD_DATE)
endif

PACKAGE_STAGING=$(CURDIR)/debian/aish

%:
	dh $@

override_dh_installsystemd:
	# Avoid deb-systemd-invoke calling systemctl in offline/chroot build/install envs,
	# which can emit: "Could not execute systemctl ... deb-systemd-invoke line 148".
	# We start the socket ourselves in postinst when systemd is actually available.
	dh_installsystemd --no-start

override_dh_auto_build:
	$(MAKE) build-binary

override_dh_auto_install:
	rm -rf $(PACKAGE_STAGING)
	$(MAKE) install NO_BUILD=1 DESTDIR=$(PACKAGE_STAGING) PREFIX=/usr SYSTEMD_UNITDIR=/lib/systemd/system

override_dh_auto_test:
	# no tests during package build
	true

override_dh_auto_clean:
	$(MAKE) clean

override_dh_gencontrol:
	# Make the .deb version include the build date, similar to other packaging flows.
	dh_gencontrol -- -v$(GENCONTROL_DEB_VERSION)

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_compress:
	dh_compress -Xskills-guide.md


